{
  "name": "Discord Bot (Python)",
  "author": "panel@netbyte.local",
  "description": "A Python-based Discord bot. Installs requirements.txt automatically and runs your main bot file.",
  "icon": "fa-robot",
  "color": "indigo",
  "docker_images": {
    "Python 3.12": "python:3.12-slim",
    "Python 3.11": "python:3.11-slim",
    "Python 3.10": "python:3.10-slim"
  },
  "startup": "cd /app && pip install -r requirements.txt -q && python {{BOT_FILE}}",
  "config": {
    "stop": null,
    "startup_done": "Logged in as"
  },
  "default_ports": [],
  "default_volumes": [],
  "variables": [
    {
      "name": "Bot File",
      "description": "The main Python file to run (relative to working directory).",
      "env_variable": "BOT_FILE",
      "default_value": "main.py",
      "field_type": "text"
    },
    {
      "name": "Bot Token",
      "description": "Your Discord bot token.",
      "env_variable": "DISCORD_TOKEN",
      "default_value": "",
      "field_type": "text"
    }
  ]
}
