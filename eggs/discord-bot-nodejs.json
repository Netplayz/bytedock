{
  "name": "Discord Bot (Node.js)",
  "author": "panel@bytedock.local",
  "description": "A Node.js Discord bot using discord.js. Runs npm install then starts your entry file.",
  "icon": "fa-robot",
  "color": "indigo",
  "docker_images": {
    "Node 20 LTS": "node:20-slim",
    "Node 18 LTS": "node:18-slim",
    "Node 22": "node:22-slim"
  },
  "startup": "cd /app && npm install --silent && node {{BOT_FILE}}",
  "config": {
    "stop": null,
    "startup_done": "Logged in"
  },
  "default_ports": [],
  "default_volumes": [],
  "variables": [
    {
      "name": "Bot Entry File",
      "description": "The main JS file to run.",
      "env_variable": "BOT_FILE",
      "default_value": "index.js",
      "field_type": "text"
    },
    {
      "name": "Bot Token",
      "description": "Your Discord bot token.",
      "env_variable": "DISCORD_TOKEN",
      "default_value": "",
      "field_type": "text"
    }
  ]
}
